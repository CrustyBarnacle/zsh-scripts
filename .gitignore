# =============================================================================
# .gitignore — zsh-scripts
# =============================================================================

# ----------------------------------------------------------------------------
# Cache and runtime data
# Never commit generated/cached data from weather.zsh or future scripts
# ----------------------------------------------------------------------------
.cache/
*.cache
cache/
*_cache.json
*_cache/

# ----------------------------------------------------------------------------
# Config files
# These contain personal settings (location, thresholds) and may contain
# sensitive values — each user maintains their own copy
# ----------------------------------------------------------------------------
*.config
config.local
config/local
.config/

# ----------------------------------------------------------------------------
# Credentials and secrets
# Belt-and-suspenders: catch any accidentally created credential files
# ----------------------------------------------------------------------------
.env
.env.*
*.secret
*.key
*.token
secrets/
credentials/

# ----------------------------------------------------------------------------
# Editor and IDE artifacts
# ----------------------------------------------------------------------------

# Vim
*.swp
*.swo
*~
.netrwhist

# VSCode
.vscode/
*.code-workspace

# JetBrains (IntelliJ, etc.)
.idea/

# Emacs
\#*\#
.\#*

# Nano
*.save

# Sublime Text
*.sublime-project
*.sublime-workspace

# ----------------------------------------------------------------------------
# macOS
# ----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ----------------------------------------------------------------------------
# Linux desktop
# ----------------------------------------------------------------------------
.Trash-*
.nfs*

# ----------------------------------------------------------------------------
# Shell history and session artifacts
# ----------------------------------------------------------------------------
.zsh_history
.bash_history
.sh_history
.zsh_sessions/

# ----------------------------------------------------------------------------
# Logs and temp files
# ----------------------------------------------------------------------------
*.log
*.tmp
*.temp
/tmp/

# ----------------------------------------------------------------------------
# Test output and scratch files
# ----------------------------------------------------------------------------
test_output/
scratch/
*.scratch
